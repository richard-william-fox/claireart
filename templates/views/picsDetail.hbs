<!DOCTYPE html>

<html>
    {{>header}}
    <body class='bg-gray-700'>
        {{>banner}}
        <div id='imageContent'>
        </div>
        <div id='imageDetails'>
            <p id='imageName' class='cfText'>Name:</p>
            <p id='imageWidth' class='cfText'>Width:</p>
            <p id='imageHeight' class='cfText'>Height:</p>
            <p id='imagePrice' class='cfText'>Price:</p>
        </div>
        <div id='detailButtons' class='rounded-md shadow'>
            <button type='button' id='addToTote' class='bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded cfButton'>Add item to Tote</button>
            <br /><br />
            <button type='button' id='buyNow' class='bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded cfButton'>Purchase now</button>
        </div>
        <div id='detailStatus'>
            <p id='toteStatus' class='cfText'></p>
        </div>
        {{>footer}}
        <script src='/js/picsDetail.js'></script>
    </body>
</html>
